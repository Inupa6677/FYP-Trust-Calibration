(define (problem example-problem)
    (:domain barman)
    (:objects shaker1 shot1 shot2 shot3 dispenser1 dispenser2 dispenser3 cocktail1 cocktail2 cocktail3 ingredient1 ingredient2 ingredient3)
    (:init
        (and (ontable shaker1) (handempty "left") (handempty "right")
             (empty shaker1) (clean shaker1)
             (empty shot1) (empty shot2) (empty shot3) (clean shot1) (clean shot2) (clean shot3)
             (dispenses dispenser1 ingredient1) (dispenses dispenser2 ingredient2) (dispenses dispenser3 ingredient3)
             (cocktail-part1 cocktail1 ingredient1) (cocktail-part1 cocktail2 ingredient2) (cocktail-part1 cocktail3 ingredient1)
             (cocktail-part2 cocktail1 ingredient3) (cocktail-part2 cocktail2 ingredient3) (cocktail-part2 cocktail3 ingredient2))
    )
    (:goal
        (and (contains shot1 cocktail1) (contains shot2 cocktail3) (contains shot3 cocktail2))
    )
    )